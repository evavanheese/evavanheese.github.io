---
interface Department {
  name: string
  url: string
}

interface EducationItem {
  school: string
  schoolUrl: string
  time: string
  degree: string
  location: string
  departments: Department[]
  supervisors: string
  internshipsLabel: string
  description: string
  bullets: string[]
}

interface Props {
  elements: EducationItem[]
}

const { elements } = Astro.props
---

<ul class="relative space-y-10 before:absolute before:left-[7px] before:top-2 before:bottom-2 before:w-0.5 before:bg-primary/30">
  {elements.map((item) => (
    <li class="relative pl-8">
      <!-- filled dot -->
      <div class="absolute left-0 top-1.5 w-3.5 h-3.5 rounded-full bg-primary border-2 border-base-100 shadow"></div>

      <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1 mb-1">
        <h3 class="text-lg font-bold">{item.degree}</h3>
        <span class="text-base font-medium text-base-content shrink-0">{item.time}</span>
      </div>

      <p class="text-base font-medium text-primary mb-1">
        {item.schoolUrl
          ? <a href={item.schoolUrl} class="underline hover:text-accent" target="_blank">{item.school}</a>
          : item.school
        }
        {' '}- {item.location}
      </p>

      {item.departments.length > 0 && (
        <p class="text-sm mb-1">
          {item.departments.map((dept, i) => (
            <>
              <a href={dept.url} class="underline hover:text-accent" target="_blank">{dept.name}</a>
              {i < item.departments.length - 1 && <span> & </span>}
            </>
          ))}
        </p>
      )}

      {item.supervisors && (
        <p class="text-sm mb-2">
          <span class="text-accent">Supervisors:</span>{' '}
          {item.supervisors}
        </p>
      )}

      {item.internshipsLabel && (
        <p class="text-sm mt-2 mb-1 font-medium">{item.internshipsLabel}</p>
      )}

      {item.bullets.length > 0 && (
        <ul class="mt-1 space-y-1 list-disc list-inside text-sm text-base-content/80">
          {item.bullets.map((bullet) => (
            <li set:html={bullet} />
          ))}
        </ul>
      )}

      {item.description && (
        <p class="text-sm text-base-content/80 mt-1" set:html={item.description} />
      )}
    </li>
  ))}
</ul>
