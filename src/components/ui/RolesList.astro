---
interface RoleItem {
  title: string
  organisation?: string
  organisationUrl?: string
  organisationSuffix?: string
  time?: string
  description?: string
}

interface Props {
  items: RoleItem[]
}

const { items } = Astro.props
---

<ul class="space-y-6">
  {items.map((item) => (
    <li>
      <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
        <span class="font-bold text-base">{item.title}</span>
        {item.time && (
          <span class="text-base font-medium text-base-content shrink-0">{item.time}</span>
        )}
      </div>
      {item.organisation && (
        <p class="text-sm text-primary font-medium">
          {item.organisationUrl
            ? (
              <>
                <a href={item.organisationUrl} class="underline hover:text-accent" target="_blank">
                  {item.organisationSuffix
                    ? item.organisation.replace(item.organisationSuffix, '')
                    : item.organisation
                  }
                </a>
                {item.organisationSuffix && <span>{item.organisationSuffix}</span>}
              </>
            )
            : item.organisation
          }
        </p>
      )}
      {item.description && (
        <div class="text-sm text-base-content/80 mt-1 space-y-0.5">
          {item.description.split('\n').map((line: string) => (
            <p set:html={line} />
          ))}
        </div>
      )}
    </li>
  ))}
</ul>
