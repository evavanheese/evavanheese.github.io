---
import Layout from '@/layouts/Layout.astro'
---

<Layout title="Conferences">
  <div class="prose max-w-none">
    <h1 class="text-3xl font-bold mb-2">Conference Presentations</h1>
    <p class="text-base-content/70 mb-10">An overview of conferences attended and presentations given.</p>

    <!-- International conferences -->
    <h2 class="text-2xl font-semibold mb-6 border-b pb-2">International Conferences</h2>

    <div class="space-y-8 mb-10">

      <div>
        <h3 class="text-lg font-bold mb-2">European Sleep Research Society (ESRS) Sleep Europe</h3>
        <ul class="space-y-1 text-sm">
          <li><span class="font-medium">2024</span> – Seville, Spain — Symposium chair, oral presentation</li>
          <li><span class="font-medium">2023</span> – Fréjus, France (course) — Poster, oral presentation</li>
          <li><span class="font-medium">2022</span> – Athens, Greece — Poster</li>
        </ul>
      </div>

      <div>
        <h3 class="text-lg font-bold mb-2">Organization for Human Brain Mapping (OHBM)</h3>
        <ul class="space-y-1 text-sm">
          <li><span class="font-medium">2025</span> – Brisbane, Australia — Posters</li>
          <li><span class="font-medium">2023</span> – Montréal, Canada — Poster</li>
          <li><span class="font-medium">2022</span> – Glasgow, UK (online) — Poster</li>
        </ul>
      </div>

      <div>
        <h3 class="text-lg font-bold mb-2">International REM Sleep Behaviour Disorder Study Group</h3>
        <ul class="space-y-1 text-sm">
          <li><span class="font-medium">2025</span> – Groningen, NL — Poster</li>
        </ul>
      </div>

      <div>
        <h3 class="text-lg font-bold mb-2">International Lewy Body Dementia Conference</h3>
        <ul class="space-y-1 text-sm">
          <li><span class="font-medium">2025</span> – Amsterdam, NL — Poster</li>
        </ul>
      </div>

      <div>
        <h3 class="text-lg font-bold mb-2">European Narcolepsy Days</h3>
        <ul class="space-y-1 text-sm">
          <li><span class="font-medium">2023</span> – Leiden, NL — Poster</li>
        </ul>
      </div>

      <div>
        <h3 class="text-lg font-bold mb-2">Sleep, Cognition & Consciousness Winter Symposium</h3>
        <ul class="space-y-1 text-sm">
          <li><span class="font-medium">2023</span> – Werfenweng, Austria — Poster</li>
        </ul>
      </div>

      <div>
        <h3 class="text-lg font-bold mb-2">Neuroscience of Dreaming (course)</h3>
        <ul class="space-y-1 text-sm">
          <li><span class="font-medium">2024</span> – Nijmegen, NL</li>
        </ul>
      </div>

    </div>

    <!-- International one-day meetings -->
    <h2 class="text-2xl font-semibold mb-6 border-b pb-2">International One-Day Meetings</h2>

    <div class="space-y-8 mb-10">

      <div>
        <h3 class="text-lg font-bold mb-2">ISMRM Benelux Annual Meeting</h3>
        <ul class="space-y-1 text-sm">
          <li><span class="font-medium">2025</span> – Hilversum, NL — Poster</li>
          <li><span class="font-medium">2024</span> – Den Bosch, NL — Oral presentation</li>
          <li><span class="font-medium">2023</span> – Brussels, Belgium — Poster</li>
        </ul>
      </div>

      <div>
        <h3 class="text-lg font-bold mb-2">Symposium on Neuroimaging, Sleep, Lifestyle & Cognition</h3>
        <ul class="space-y-1 text-sm">
          <li><span class="font-medium">2025</span> – Montréal, Canada — Poster</li>
        </ul>
      </div>

    </div>

    <!-- National conferences -->
    <h2 class="text-2xl font-semibold mb-6 border-b pb-2">National Conferences</h2>

    <div class="space-y-8 mb-10">

      <div>
        <h3 class="text-lg font-bold mb-2">SLAAP (National Sleep Conference)</h3>
        <ul class="space-y-1 text-sm">
          <li><span class="font-medium">2025</span> – Eindhoven, NL — Symposium chair, oral presentation</li>
          <li><span class="font-medium">2023</span> – Papendal, NL — Symposium chair, oral presentation</li>
          <li><span class="font-medium">2021</span> – Online — Poster</li>
        </ul>
      </div>

    </div>

    <!-- National one-day meetings -->
    <h2 class="text-2xl font-semibold mb-6 border-b pb-2">National One-Day Meetings</h2>
    <p class="text-sm">
      Regular attendance of Sleep Spring and Fall Symposia of the Dutch Society for Sleep-Wake Research (2021–2025),
      the Dutch Parkinson Scientists Congress (2022–2025), and the Amsterdam Neuroscience Annual Meeting (2022–2026).
    </p>

    <div class="mt-10">
      <a href="/cv" class="btn btn-outline btn-sm">Back to CV</a>
    </div>

  </div>
</Layout>
