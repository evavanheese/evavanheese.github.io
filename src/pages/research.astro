---
import Layout from "@/layouts/Layout.astro";
import { profile } from "@/settings";
import { RESEARCH_ICONS } from "@/data/researchIcons";
import { consortia, currentProjects } from "@/data/research";
const { research_areas } = profile;
---

<Layout title="Research">
  <div class="prose max-w-none">

    <!-- Research Statement -->
    <h1 class="text-3xl font-bold mb-6">Research</h1>
    <p class="text-lg mb-12">
      I investigate sleep, neurodegeneration, and brain clearance using MRI. This research includes a central role in coordinating international consortia, focussed on pooling imaging data to improve power, reproducibility, and diversity across datasets. I actively promote open science through my research, collaborations, and outreach initiatives aimed at the broader community.
    </p>

    <!-- Research Areas -->
    <h2 class="text-2xl font-bold mb-6 border-b pb-2">Research Areas</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-16 not-prose">
      {research_areas.map((area) => (
        <div class="card bg-base-200 shadow-sm">
          <div class="card-body">
            <div class="flex items-center gap-3 mb-2">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="size-6 stroke-accent shrink-0"
                set:html={RESEARCH_ICONS[area.field as keyof typeof RESEARCH_ICONS] ?? RESEARCH_ICONS['computer-science']}
              />
              <h3 class="text-lg font-bold text-base-content">{area.title}</h3>
            </div>
            <p class="text-sm text-base-content/80">{area.description}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Current Projects -->
    <h2 class="text-2xl font-bold mb-6 border-b pb-2">Current Projects</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-16 not-prose">
      {currentProjects.map((project) => (
        <div class="card bg-base-200 shadow-sm">
          <div class="card-body">
            <h3 class="text-lg font-bold text-primary mb-1">{project.name}</h3>
            <p class="text-sm text-base-content/80 mb-3">{project.subtitle}</p>
            <div class="mb-3">
              <div class="flex justify-between text-xs text-base-content/60 mb-1">
                <span>Progress</span>
                <span>{project.percentage}%</span>
              </div>
              <progress
                class="progress progress-primary w-full"
                value={project.percentage}
                max="100"
              ></progress>
            </div>
            <p class="text-xs text-base-content/70">
              <span class="font-medium text-accent">Status:</span>{' '}
              {project.statusLink
                ? <><a href={project.statusLink} class="underline hover:text-accent" target="_blank">Preregistration available</a>{project.status.replace('Preregistration available,', ',')}</>
                : project.status
              }
            </p>
          </div>
        </div>
      ))}
    </div>

    <!-- Consortia & Networks -->
    <h2 class="text-2xl font-bold mb-6 border-b pb-2">Consortia & Networks</h2>
    <div class="not-prose space-y-4 mb-12">
      {consortia.map((c) => (
        <div class="card bg-base-200 shadow-sm">
          <div class="card-body py-4">
            <div class="flex flex-wrap items-baseline justify-between gap-2">
              <a href={c.url} class="text-lg font-bold underline hover:text-accent" target="_blank">{c.name}</a>
              <span class="text-sm text-primary font-medium">{c.role}</span>
            </div>
            <p class="text-sm text-base-content/80 mt-1">{c.description}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</Layout>
