---
import Layout from "@/layouts/Layout.astro";
import publications from "@/data/publications.json";
import { highlightAuthor } from "@/lib/utils";

const firstAuthorPapers = publications.filter(
  (p) => p.is_first_author && !p.is_preprint
);
const firstAuthorPreprints = publications.filter(
  (p) => p.is_first_author && p.is_preprint
);
const firstAuthorAll = [...firstAuthorPapers, ...firstAuthorPreprints];

const coAuthoredPapers = publications.filter(
  (p) => !p.is_first_author && !p.is_preprint
);

const preregistrations = publications.filter((p) => p.type === "preregistration");
---

<Layout title="Papers">
  <div class="prose max-w-none">
    <h1 class="text-3xl font-bold mb-8">Publications</h1>

    <!-- First-author papers -->
    <h2 class="text-2xl font-semibold mb-6 mt-10">First-author papers</h2>
    <div class="space-y-8">
      {
        firstAuthorAll.map((paper) => (
          <div class="card bg-base-200">
            <div class="card-body">
              <h3 class="card-title text-xl">
                <a href={paper.link} class="hover:text-accent">
                  {paper.title}
                </a>
                {paper.is_preprint && (
                  <span class="badge badge-warning badge-sm ml-2">Preprint</span>
                )}
              </h3>
              <p class="text-base mb-2">
                <span class="font-medium">Authors:</span>{" "}
                <span set:html={highlightAuthor(paper.authors)} />
              </p>
              <p class="text-sm mb-3">
                <span class="italic">{paper.journal}</span>
                {paper.journal && paper.time && " • "}
                {paper.time}
              </p>
              {paper.abstract && (
                <p class="text-sm text-base-content/80">{paper.abstract}</p>
              )}
              <div class="card-actions justify-end mt-4">
                <a
                  href={paper.link}
                  class="btn btn-sm btn-secondary text-secondary-content"
                  target="_blank"
                >
                  Read Paper
                </a>
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <!-- Co-authored papers (peer-reviewed only) -->
    <h2 class="text-2xl font-semibold mb-6 mt-12">Co-authored papers</h2>
    <div class="space-y-8">
      {
        coAuthoredPapers.map((paper) => (
          <div class="card bg-base-200">
            <div class="card-body">
              <h3 class="card-title text-xl">
                <a href={paper.link} class="hover:text-accent">
                  {paper.title}
                </a>
              </h3>
              <p class="text-base mb-2">
                <span class="font-medium">Authors:</span>{" "}
                <span set:html={highlightAuthor(paper.authors)} />
              </p>
              <p class="text-sm mb-3">
                <span class="italic">{paper.journal}</span>
                {paper.journal && paper.time && " • "}
                {paper.time}
              </p>
              {paper.abstract && (
                <p class="text-sm text-base-content/80">{paper.abstract}</p>
              )}
              <div class="card-actions justify-end mt-4">
                <a
                  href={paper.link}
                  class="btn btn-sm btn-secondary text-secondary-content"
                  target="_blank"
                >
                  Read Paper
                </a>
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <!-- Preregistrations (added manually) -->
    {preregistrations.length > 0 && (
      <>
        <h2 class="text-2xl font-semibold mb-6 mt-12">Preregistrations</h2>
        <div class="space-y-8">
          {
            preregistrations.map((paper) => (
              <div class="card bg-base-200">
                <div class="card-body">
                  <h3 class="card-title text-xl">
                    <a href={paper.link} class="hover:text-accent">
                      {paper.title}
                    </a>
                  </h3>
                  <p class="text-base mb-2">
                    <span class="font-medium">Authors:</span>{" "}
                    <span set:html={highlightAuthor(paper.authors)} />
                  </p>
                  <p class="text-sm mb-3">
                    <span class="italic">{paper.journal}</span>
                    {paper.journal && paper.time && " • "}
                    {paper.time}
                  </p>
                  {paper.abstract && (
                    <p class="text-sm text-base-content/80">{paper.abstract}</p>
                  )}
                  <div class="card-actions justify-end mt-4">
                    <a
                      href={paper.link}
                      class="btn btn-sm btn-secondary text-secondary-content"
                      target="_blank"
                    >
                      View
                    </a>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </>
    )}
  </div>
</Layout>
