---
import Layout from '@/layouts/Layout.astro'
import { education, leadershipRoles, teachingRoles, grantsAwards, certificates, programmingSkills } from '../data/cv'
import EducationTimeline from '@/components/ui/EducationTimeline.astro'
import RolesList from '@/components/ui/RolesList.astro'
import List from '@/components/ui/List.astro'

const orderEducation = (a: { time: string }, b: { time: string }) => {
  const presentValues = ['present', 'now', 'current', 'today']
  if (presentValues.includes(a.time?.split(' - ')[1]?.toLowerCase())) return -1
  if (presentValues.includes(b.time?.split(' - ')[1]?.toLowerCase())) return 1
  const dateA = new Date(a.time?.split(' - ')[1])
  const dateB = new Date(b.time?.split(' - ')[1])
  return dateB.getTime() - dateA.getTime()
}

const orderedEducation = [...education].sort(orderEducation)
---

<Layout title="CV">

  <!-- Education -->
  <section class='mb-12'>
    <h2 class='text-2xl font-bold mb-6 border-b pb-2'>Education and Training</h2>
    <EducationTimeline elements={orderedEducation} />
  </section>

  <!-- Leadership -->
  <section class='mb-12'>
    <h2 class='text-2xl font-bold mb-6 border-b pb-2'>Leadership and Community Roles</h2>
    <RolesList items={leadershipRoles} />
  </section>

  <!-- Teaching -->
  <section class='mb-12'>
    <h2 class='text-2xl font-bold mb-6 border-b pb-2'>Teaching and Mentorship Roles</h2>
    <RolesList items={teachingRoles} />
  </section>

  <!-- Grants & Awards -->
  <section class='mb-12'>
    <h2 class='text-2xl font-bold mb-6 border-b pb-2'>Grants & Awards</h2>
    <RolesList items={grantsAwards} />
  </section>

  <!-- Certificates -->
  <section class='mb-12'>
    <h2 class='text-2xl font-bold mb-6 border-b pb-2'>Certificates & Qualifications</h2>
    <RolesList items={certificates} />
  </section>

  <!-- Programming Skills -->
  <section class='mb-12'>
    <h2 class='text-2xl font-bold mb-6 border-b pb-2'>Programming & Computational Skills</h2>
    <List listTitle='' listItems={programmingSkills} />
  </section>

  <!-- Links -->
  <section class='mb-12 flex gap-4'>
    <a href='/papers' class='btn btn-outline btn-sm'>View Publications</a>
    <a href='/conferences' class='btn btn-outline btn-sm'>View Conference Presentations</a>
  </section>

</Layout>
